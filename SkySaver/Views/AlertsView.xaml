<UserControl x:Class="SkySaver.Views.AlertsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <Grid Margin="40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="Price Alerts" FontSize="28" FontWeight="Bold"
                       Foreground="#1A1A2E"/>
            <TextBlock Text="We'll notify you when prices drop below your target"
                       FontSize="14" Foreground="#6B7280" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Loading -->
        <ProgressBar Grid.Row="1" IsIndeterminate="True" Height="4"
                     Foreground="#6366F1" VerticalAlignment="Top"
                     Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"/>

        <!-- Alerts list -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Empty state -->
                <StackPanel HorizontalAlignment="Center" Margin="0,80,0,0"
                            Visibility="{Binding Alerts.Count, Converter={StaticResource ZeroToVisibilityConverter}}">
                    <TextBlock Text="🔔" FontSize="48" HorizontalAlignment="Center"/>
                    <TextBlock Text="No alerts yet" FontSize="18" FontWeight="SemiBold"
                               Foreground="#374151" HorizontalAlignment="Center" Margin="0,12,0,0"/>
                    <TextBlock Text="Search for flights and save an alert to get started."
                               Foreground="#9CA3AF" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                </StackPanel>

                <ItemsControl ItemsSource="{Binding Alerts}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border CornerRadius="12" Margin="0,0,0,12"
                                    Padding="20" Effect="{StaticResource CardShadow}">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="White"/>
                                        <Setter Property="Opacity"    Value="1"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                <Setter Property="Background" Value="#F9FAFB"/>
                                                <Setter Property="Opacity"    Value="0.7"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <StackPanel Orientation="Horizontal">
                                              <TextBlock Text="{Binding DisplayRoute, Mode=OneWay}"
                                                       FontSize="17" FontWeight="Bold" Foreground="#1A1A2E"/>
                                            <!-- Active badge -->
                                            <Border Background="#D1FAE5" CornerRadius="4" Padding="6,2"
                                                    Margin="10,0,0,0"
                                                    Visibility="{Binding IsActive, Converter={StaticResource BoolToVisibilityConverter}}">
                                                <TextBlock Text="Active" Foreground="#065F46" FontSize="11"/>
                                            </Border>
                                            <Border Background="#F3F4F6" CornerRadius="4" Padding="6,2"
                                                    Margin="10,0,0,0"
                                                    Visibility="{Binding IsActive, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                                <TextBlock Text="Paused" Foreground="#6B7280" FontSize="11"/>
                                            </Border>
                                        </StackPanel>

                                        <TextBlock Margin="0,4,0,0" Foreground="#6B7280" FontSize="13">
                                            <Run Text="Departure:"/>
                                            <Run Text="{Binding DisplayDate, Mode=OneWay}"/>
                                        </TextBlock>

                                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                            <TextBlock Text="Target: " Foreground="#6B7280" FontSize="13"/>
                                            <TextBlock Foreground="#6366F1" FontWeight="SemiBold" FontSize="13">
                                                <Run Text="{Binding TargetPrice, StringFormat='{}{0:F2}'}"/>
                                                <Run Text=" "/>
                                                <Run Text="{Binding Currency}"/>
                                            </TextBlock>
                                            <TextBlock Margin="12,0,0,0" Foreground="#9CA3AF" FontSize="12"
                                                       Visibility="{Binding LastCheckedPrice, Converter={StaticResource NullToVisibilityConverter}}">
                                                <Run Text="Last seen:"/>
                                                <Run Text="{Binding LastCheckedPrice, StringFormat='{}{0:F2}'}"/>
                                                <Run Text=" "/>
                                                <Run Text="{Binding Currency}"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Actions -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0,0,0">
                                        <Button Content="{Binding IsActive, Converter={StaticResource BoolToToggleTextConverter}}"
                                                Command="{Binding DataContext.ToggleActiveCommand,
                                                          RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding .}"
                                                Width="70">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <!-- Default: green/Resume appearance (IsActive=False) -->
                                                    <Setter Property="Background"      Value="Transparent"/>
                                                    <Setter Property="Foreground"      Value="#059669"/>
                                                    <Setter Property="BorderBrush"     Value="#059669"/>
                                                    <Setter Property="BorderThickness" Value="1.5"/>
                                                    <Setter Property="Padding"         Value="8,6"/>
                                                    <Setter Property="Cursor"          Value="Hand"/>
                                                    <Setter Property="FontSize"        Value="12"/>
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border Background="{TemplateBinding Background}"
                                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                                        CornerRadius="6"
                                                                        Padding="{TemplateBinding Padding}">
                                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                                      VerticalAlignment="Center"/>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter Property="Background" Value="#ECFDF5"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                    <Style.Triggers>
                                                        <!-- IsActive=True: switch to amber/Pause appearance -->
                                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                            <Setter Property="Foreground"  Value="#D97706"/>
                                                            <Setter Property="BorderBrush" Value="#D97706"/>
                                                            <Setter Property="Template">
                                                                <Setter.Value>
                                                                    <ControlTemplate TargetType="Button">
                                                                        <Border Background="{TemplateBinding Background}"
                                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                                                CornerRadius="6"
                                                                                Padding="{TemplateBinding Padding}">
                                                                            <ContentPresenter HorizontalAlignment="Center"
                                                                                              VerticalAlignment="Center"/>
                                                                        </Border>
                                                                        <ControlTemplate.Triggers>
                                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                                <Setter Property="Background" Value="#FFFBEB"/>
                                                                            </Trigger>
                                                                        </ControlTemplate.Triggers>
                                                                    </ControlTemplate>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                        <Button Content="Delete"
                                                Command="{Binding DataContext.DeleteCommand,
                                                          RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding .}"
                                                Style="{StaticResource DangerButtonStyle}"
                                                Margin="0,6,0,0" Width="70"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
