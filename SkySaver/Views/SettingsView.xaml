<UserControl x:Class="SkySaver.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <Grid MaxWidth="520" Margin="40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="Settings" FontSize="28" FontWeight="Bold"
                       Foreground="#1A1A2E"/>
            <TextBlock Text="Configure your data source and API key"
                       FontSize="14" Foreground="#6B7280" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Settings Card -->
        <Border Grid.Row="1" Background="White" CornerRadius="16"
                Padding="32" Effect="{StaticResource CardShadow}">
            <StackPanel>

                <!-- Data Source -->
                <TextBlock Text="DATA SOURCE" Style="{StaticResource LabelStyle}"/>

                <RadioButton Content="Mock Data  (offline — no API key required)"
                             IsChecked="{Binding IsMockMode, Mode=TwoWay}"
                             Margin="0,8,0,4" FontSize="14" Foreground="#374151"
                             Cursor="Hand"/>

                <RadioButton Content="Live API  (Aviationstack)"
                             IsChecked="{Binding IsLiveMode, Mode=TwoWay}"
                             Margin="0,0,0,24" FontSize="14" Foreground="#374151"
                             Cursor="Hand"/>

                <!-- API Key (shown only in Live mode) -->
                <StackPanel Visibility="{Binding IsLiveMode,
                            Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock Text="AVIATIONSTACK API KEY" Style="{StaticResource LabelStyle}"/>
                    <TextBox Text="{Binding AviationStackApiKey, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource InputStyle}"
                             Tag="Paste your free API key here"/>
                    <TextBlock Margin="0,8,0,0" FontSize="11" Foreground="#9CA3AF"
                               TextWrapping="Wrap"
                               Text="Get a free key at aviationstack.com — no credit card required. Free plan supports HTTP only."/>
                </StackPanel>

                <!-- Fallback notice (shown in Live mode) -->
                <Border Background="#FEF9C3" CornerRadius="8" Padding="12" Margin="0,16,0,0"
                        Visibility="{Binding IsLiveMode,
                        Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock Foreground="#92400E" FontSize="12" TextWrapping="Wrap"
                               Text="If the API call fails or returns no results, SkySaver automatically falls back to mock data so you always get results."/>
                </Border>

                <!-- Mode indicator badge -->
                <Border Background="#EEF2FF" CornerRadius="8" Padding="12" Margin="0,20,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Current mode: " Foreground="#6B7280" FontSize="13"/>
                        <TextBlock Text="{Binding ModeLabel}"
                                   Foreground="#4338CA" FontWeight="SemiBold" FontSize="13"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </Border>
    </Grid>
</UserControl>
